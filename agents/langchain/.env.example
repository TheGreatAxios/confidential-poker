# Required
PRIVATE_KEY=
LLM_API_KEY=
FACTORY_ADDRESS=
CHIP_TOKEN_ADDRESS=

# Optional — defaults below
RPC_URL=https://base-sepolia-testnet.skalenodes.com/v1/base-testnet
CHAIN_ID=324705682

# LLM Configuration
LLM_PROVIDER=anthropic
# Supported: anthropic, openai, xai, google-genai, openrouter
LLM_MODEL=claude-sonnet-4-6

# Memory (memory, sqlite, or postgres)
MEMORY_BACKEND=memory
DATABASE_URL=

# Strategy (shark, fox, owl, bull, cat, wolf, custom)
STRATEGY=wolf
CUSTOM_PROMPT=

# Loop timing
POLL_INTERVAL_MS=5000
IDLE_BALANCE_CHECK_MS=60000

# Logging
LOG_LEVEL=info
