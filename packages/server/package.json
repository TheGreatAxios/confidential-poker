{
  "name": "@confidential-poker/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node",
    "start": "bun run src/index.ts",
    "gen-wallets": "bun run scripts/gen-wallets.ts",
    "run-game": "bun run scripts/run-game.ts",
    "run-agent": "bun run scripts/run-agent-loop.ts",
    "run-agent:shark": "bun run scripts/run-agent-loop.ts --agent shark",
    "run-agent:fox": "bun run scripts/run-agent-loop.ts --agent fox",
    "run-agent:owl": "bun run scripts/run-agent-loop.ts --agent owl",
    "run-agent:bull": "bun run scripts/run-agent-loop.ts --agent bull",
    "run-agent:cat": "bun run scripts/run-agent-loop.ts --agent cat",
    "run-agent:wolf": "bun run scripts/run-agent-loop.ts --agent wolf"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@skalenetwork/bite": "0.8.1-develop.0",
    "@x402/core": "^2.9.0",
    "@x402/evm": "^2.9.0",
    "@x402/hono": "^2.9.0",
    "hono": "^4.6.14",
    "viem": "^2.47.10"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "bun-types": "^1.1.0",
    "@noble/curves": "^1.7.0"
  }
}
